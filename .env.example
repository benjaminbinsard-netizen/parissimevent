# ──────────────────────────────────────────────────────────────────
# Parissim Event — variables d'environnement
# Copier ce fichier en `.env` pour le local, ou définir ces variables
# dans Vercel → Settings → Environment Variables pour la production.
# ──────────────────────────────────────────────────────────────────

# ── Base de données (Neon Postgres) ────────────────────────────────
# Fournies AUTOMATIQUEMENT par l'intégration Neon de Vercel une fois
# la base connectée au projet. En local, copier ces deux valeurs
# depuis Vercel (Storage → ta base → .env.local) ou le dashboard Neon.
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"          # connexion poolée (runtime)
DATABASE_URL_UNPOOLED="postgresql://user:password@host/db?sslmode=require" # connexion directe (migrations)

# ── Accès au dashboard /admin ──────────────────────────────────────
# Mot de passe pour se connecter sur /admin.
ADMIN_PASSWORD="choisis-un-mot-de-passe-fort"
# Clé secrète qui signe le cookie de session (≥ 16 caractères).
# Générer une valeur aléatoire, ex. : openssl rand -base64 32
AUTH_SECRET="remplace-par-une-chaine-aleatoire-longue"

# ── URL publique (liens dans les emails) ───────────────────────────
PUBLIC_SITE_URL="https://parissimevent.vercel.app"

# ── Emails (optionnel) ─────────────────────────────────────────────
# Tant que SMTP_HOST est vide, le formulaire fonctionne quand même :
# les demandes sont enregistrées et visibles dans /admin, seuls les
# emails ne partent pas.
NOTIFY_EMAIL="contact@parissim-event.fr"   # adresse interne qui reçoit chaque demande
MAIL_FROM="Parissim Event <no-reply@parissim-event.fr>"
SMTP_HOST=""        # ex. OVH: ssl0.ovh.net  |  Gmail: smtp.gmail.com
SMTP_PORT="587"     # OVH: 587 (secure=false) |  Gmail: 465 (secure=true)
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""        # Gmail: mot de passe d'application, pas le mot de passe du compte
